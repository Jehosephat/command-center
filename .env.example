# GalaChain Command Center - Environment Variables Example
# Copy this file to .env and adjust values as needed

# ========================================
# Server Configuration (NestJS)
# ========================================

# Server port (default 3000)
PORT=3000

# GalaChain environment: production | stage
GALACHAIN_ENV=stage

# GalaChain Gateway URL (for chaincode operations)
# This is the complete URL to the token contract - all chaincode invocations go through the gateway
# Production: https://gateway-mainnet.galachain.com/api/asset/token-contract
# Stage: https://galachain-gateway-chain-platform-stage-chain-platform-eks.stage.galachain.com/api/asset/token-contract
GALACHAIN_GATEWAY_URL=https://galachain-gateway-chain-platform-stage-chain-platform-eks.stage.galachain.com/api/asset/token-contract

# ========================================
# Marketplace / App Wallet (Server)
# ========================================

# App wallet private key (64-char hex, no 0x prefix) - used for server-side signing
# This wallet receives buyer payments, distributes to sellers, and mints NFTs
FULFILLER_PRIVATE_KEY=
FULFILLER_ADDRESS=eth|

# Platform fee percentage taken from each sale (default 2.5%)
PLATFORM_FEE_PERCENT=2.5

# SQLite database path (default ./data/marketplace.sqlite)
DATABASE_PATH=./data/marketplace.sqlite

# ========================================
# Client Configuration (Vue/Vite)
# ========================================
# Note: These are in client/.env and must be prefixed with VITE_

# API base URL (leave empty for same-origin in production)
# VITE_API_BASE_URL=

# GalaChain environment for client
# VITE_GALACHAIN_ENV=stage

# GalaChain Gateway URL for client (same as server, must be VITE_ prefixed)
# VITE_GALACHAIN_GATEWAY_URL=https://galachain-gateway-chain-platform-stage-chain-platform-eks.stage.galachain.com/api/asset/token-contract
